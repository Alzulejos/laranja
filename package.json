{
  "name": "laranja-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "scan:express": "tsx packages/scanner/src/dev-scan.ts examples/express-basic",
    "build:express": "tsx packages/runtime/src/dev-build.ts examples/express-basic",
    "synth:express": "tsx packages/cdk/src/dev-synth.ts examples/express-basic",
    "laranja": "tsx packages/cli/src/cli.ts",
    "deploy:express": "tsx packages/cli/src/cli.ts deploy examples/express-basic",
    "destroy:express": "tsx packages/cli/src/cli.ts destroy examples/express-basic",
    "deploy:cf": "tsx packages/cli/src/cli.ts deploy examples/express-codefirst",
    "destroy:cf": "tsx packages/cli/src/cli.ts destroy examples/express-codefirst",
    "log:cf": "tsx packages/cli/src/cli.ts logs examples/express-codefirst",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  }
}
