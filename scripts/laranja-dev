#!/usr/bin/env bash
# laranja-dev — run the CLI straight from the monorepo SOURCE, in any project.
#
# Local development only. Never published.
#
# Why source and not the built bin: `packages/cli/dist/cli.js` resolves its
# @alzulejos/* deps to the workspace symlinks anyway, and the dist bin isn't
# marked executable — so running the TypeScript entry through tsx is both closer
# to what you edit and less surprising. Every invocation picks up your latest
# edits with no build step.
#
# Usage (from inside any project):
#   laranja-dev deploy
#   laranja-dev deploy --stage prod
#   laranja-dev destroy
#
# The CLI takes the project dir as an optional argument and defaults to $PWD, so
# this works from wherever you run it.
set -euo pipefail

LARANJA_REPO="${LARANJA_REPO:-/Users/ferasallaou/dev/laranja}"
CLI_ENTRY="$LARANJA_REPO/packages/cli/src/cli.ts"

if [[ ! -f "$CLI_ENTRY" ]]; then
  echo "laranja-dev: can't find the CLI at $CLI_ENTRY" >&2
  echo "  Set LARANJA_REPO to your laranja checkout, e.g." >&2
  echo "  export LARANJA_REPO=$HOME/dev/laranja" >&2
  exit 1
fi

# Run tsx from the monorepo so it resolves the workspace packages, but keep the
# caller's working directory — that's the project being deployed.
exec npx --prefix "$LARANJA_REPO" tsx "$CLI_ENTRY" "$@"
